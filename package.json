    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "@types/react-native": "~0.73.0",
    "@types/uuid": "^9.0.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~7.1.0",
    "patch-package": "^8.0.1",
    "typescript": "^5.3.0"
