{
  "name": "steam-backlog-manager",
  "version": "1.0.0",
  "description": "A mobile app to manage your Steam gaming backlog",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:apk": "eas build --platform android --profile apk",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "postinstall": "npx patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-native-community/slider": "4.5.2",
    "@react-navigation/native": "^6.1.17",
    "@supabase/supabase-js": "^2.43.0",
    "expo": "~51.0.0",
    "expo-auth-session": "~5.5.0",
    "expo-background-fetch": "~12.0.1",
    "expo-blur": "~13.0.0",
    "expo-build-properties": "~0.12.5",
    "expo-constants": "~16.0.0",
    "expo-crypto": "~13.0.0",
    "expo-document-picker": "~12.0.2",
    "expo-font": "~12.0.0",
    "expo-keep-awake": "~13.0.2",
    "expo-linear-gradient": "~13.0.0",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.2",
    "expo-sharing": "~12.0.1",
    "expo-splash-screen": "~0.27.0",
    "expo-sqlite": "~14.0.0",
    "expo-status-bar": "~1.12.0",
    "expo-system-ui": "~3.0.7",
    "expo-task-manager": "~11.8.2",
    "expo-web-browser": "~13.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.0",
    "react-native-purchases": "^9.11.2",
    "react-native-purchases-ui": "^9.11.2",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "react-native-view-shot": "^4.0.3",
