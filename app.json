{
  "expo": {
    "name": "Steam Backlog",
    "slug": "steam-backlog-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.steambacklog.app"
    },
    "android": {
      "package": "com.steambacklog.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "steambacklog"
  }
}
