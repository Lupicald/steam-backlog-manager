{
  "expo": {
    "name": "BacklogFlow",
    "slug": "steam-backlog-manager",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d14"
    },
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.backlogflow.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is not used by this app.",
        "NSPhotoLibraryUsageDescription": "Photo library is not used by this app."
      }
    },
    "android": {
      "package": "com.backlogflow.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#05051a"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "backlogflow"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "backlogflow",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3c78a46e-6c04-4b9f-8388-41105b176f99"
      }
    },
    "owner": "milsde"
  }
}